# Base de donnees MariaDB (IONOS)
# Format: mysql://utilisateur:motdepasse@host:3306/nom_base
DATABASE_URL="mysql://user:password@host:3306/fermafrik"

# Pour exporter les donnees depuis Neon (avant migration)
# NEON_DATABASE_URL="postgresql://user:pass@host/neondb?sslmode=require"

# NextAuth.js v5
AUTH_SECRET="votre-secret-nextauth-32-caracteres-minimum"
NEXTAUTH_URL="http://localhost:3000"

# Application
NEXT_PUBLIC_APP_NAME="FermAfrik"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
